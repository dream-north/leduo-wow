{
  "name": "leduo-wow",
  "version": "0.7.1",
  "description": "Mac voice input app powered by Qwen ASR and LLM",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:native": "cd src/native-keyboard-listener && npm run build",
    "postinstall": "electron-builder install-app-deps && npm run build:native",
    "pack": "electron-builder --mac --config",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:renderer": "vue-tsc --noEmit -p src/renderer/tsconfig.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:renderer",
    "lint": "eslint . --ext .ts,.vue",
    "test": "vitest run"
  },
  "dependencies": {
    "@jitsi/robotjs": "^0.6.21",
    "electron-store": "^8.2.0",
    "openai": "^4.77.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "pinia": "^2.3.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.0.18",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0"
  }
}
